      "sentence": "Little Lily was a kind girl.",
      "word_count": 6,
      "approx_duration_sec": 2.45
    },
    {
      "scene_index": 1,
      "sentence": "One day, she saw a small bird with a hurt wing.",
      "word_count": 11,
      "approx_duration_sec": 4.49
    },
    {
      "scene_index": 2,
      "sentence": "\"Oh no!\" said Lily.",
      "word_count": 4,
      "approx_duration_sec": 1.63
    },
    {
      "scene_index": 3,
      "sentence": "\"You need help!\" Lily gently picked up the bird and took it home.",
      "word_count": 13,
      "approx_duration_sec": 5.31
    },
    {
      "scene_index": 4,
      "sentence": "She made a soft nest for the bird and gave it yummy food and water.",
      "word_count": 15,
      "approx_duration_sec": 6.12
    },
    {
      "scene_index": 5,
      "sentence": "The bird's wing got better, and soon it could fly again.",
      "word_count": 11,
      "approx_duration_sec": 4.49
    },
    {
      "scene_index": 6,
      "sentence": "\"Yay!\" cheered Lily.",
      "word_count": 3,
      "approx_duration_sec": 1.22
    },
    {
      "scene_index": 7,
      "sentence": "The bird flew up and perched on Lily's hand.",
      "word_count": 9,
      "approx_duration_sec": 3.67
    },
    {
      "scene_index": 8,
      "sentence": "\"Goodbye, little bird!\" said Lily.",
      "word_count": 5,
      "approx_duration_sec": 2.04
    },
    {
      "scene_index": 9,
      "sentence": "\"I'm so happy I could help you.\" The bird chirped a thank-you and flew away.",
