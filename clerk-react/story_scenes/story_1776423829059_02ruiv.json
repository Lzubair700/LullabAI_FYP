    },
    {
      "scene_index": 2,
      "sentence": "\"Yum!\" said Duck, and she took a big bite.",
      "word_count": 9,
      "approx_duration_sec": 3.33
    },
    {
      "scene_index": 3,
      "sentence": "But then Duck saw that the berry had a small bite taken out of it already.",
      "word_count": 16,
      "approx_duration_sec": 5.93
    },
    {
      "scene_index": 4,
      "sentence": "\"Oh no, someone else took a bite!\" Duck frowned.",
      "word_count": 9,
      "approx_duration_sec": 3.33
    },
    {
      "scene_index": 5,
      "sentence": "She put the berry back down and swam away.",
      "word_count": 9,
      "approx_duration_sec": 3.33
    },
    {
      "scene_index": 6,
      "sentence": "Soon, Duck found her own fresh, red berry.",
      "word_count": 8,
      "approx_duration_sec": 2.96
    },
    {
      "scene_index": 7,
      "sentence": "She ate the whole thing happily.",
      "word_count": 6,
      "approx_duration_sec": 2.22
    },
    {
      "scene_index": 8,
      "sentence": "Later, a little fish swam up to Duck.",
      "word_count": 8,
      "approx_duration_sec": 2.96
    },
    {
      "scene_index": 9,
      "sentence": "\"Can I have some of your food?\" asked the fish.",
