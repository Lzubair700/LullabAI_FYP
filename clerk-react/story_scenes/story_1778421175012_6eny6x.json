    {
      "scene_index": 0,
      "sentence": "Tommy the Pup Tommy was a happy pup who loved to play.",
      "word_count": 12,
      "approx_duration_sec": 4.49
    },
    {
      "scene_index": 1,
      "sentence": "One sunny day, Tommy was in the yard when he saw a shiny ball.",
      "word_count": 14,
      "approx_duration_sec": 5.23
    },
    {
      "scene_index": 2,
      "sentence": "\"Ooh, I want that!\" he said.",
      "word_count": 6,
      "approx_duration_sec": 2.24
    },
    {
      "scene_index": 3,
      "sentence": "Tommy took the ball, even though it wasn't his.",
      "word_count": 9,
      "approx_duration_sec": 3.36
    },
    {
      "scene_index": 4,
      "sentence": "Later, Tommy's owner asked, \"Tommy, do you know where my ball is?\" Tommy felt sad.",
      "word_count": 15,
      "approx_duration_sec": 5.61
    },
    {
      "scene_index": 5,
      "sentence": "He knew he should tell the truth.",
      "word_count": 7,
      "approx_duration_sec": 2.62
    },
    {
      "scene_index": 6,
      "sentence": "\"I took it,\" he said.",
      "word_count": 5,
      "approx_duration_sec": 1.87
    },
    {
      "scene_index": 7,
      "sentence": "His owner smiled.",
      "word_count": 3,
      "approx_duration_sec": 1.12
    },
    {
      "scene_index": 8,
      "sentence": "\"I'm glad you told me.",
      "word_count": 5,
      "approx_duration_sec": 1.87
    },
    {
      "scene_index": 9,
      "sentence": "Honesty is the best policy.\" From then on, Tommy always tried to be honest.",
      "word_count": 14,
      "approx_duration_sec": 5.23
    },
    {
      "scene_index": 10,
      "sentence": "He learned that telling the truth made him feel good inside.",
      "word_count": 11,
      "approx_duration_sec": 4.11
    },
    {
      "scene_index": 11,
      "sentence": "Moral: Honesty is the best policy.",
      "word_count": 6,
      "approx_duration_sec": 2.24
    }
  ]
