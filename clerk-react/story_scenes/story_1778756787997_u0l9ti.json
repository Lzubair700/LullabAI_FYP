    {
      "scene_index": 0,
      "sentence": "The Lost Toy Lily was a little girl who loved her stuffed bear, Teddy.",
      "word_count": 14,
      "approx_duration_sec": 5.05
    },
    {
      "scene_index": 1,
      "sentence": "One day, Lily was playing in the park when Teddy fell out of her bag.",
      "word_count": 15,
      "approx_duration_sec": 5.41
    },
    {
      "scene_index": 2,
      "sentence": "\"Oh no!\" said Lily.",
      "word_count": 4,
      "approx_duration_sec": 1.44
    },
    {
      "scene_index": 3,
      "sentence": "\"I lost Teddy!\" Lily felt sad, but she knew she had to be honest.",
      "word_count": 14,
      "approx_duration_sec": 5.05
    },
    {
      "scene_index": 4,
      "sentence": "She told the park keeper, \"I lost my toy bear.\" The kind keeper helped Lily look all over.",
      "word_count": 18,
      "approx_duration_sec": 6.49
    },
    {
      "scene_index": 5,
      "sentence": "After a while, they found Teddy!",
      "word_count": 6,
      "approx_duration_sec": 2.16
    },
    {
      "scene_index": 6,
      "sentence": "Lily gave the keeper a big smile.",
      "word_count": 7,
      "approx_duration_sec": 2.52
    },
    {
      "scene_index": 7,
      "sentence": "\"Thank you for helping me find my bear.\" From that day on, Lily always tried to be honest.",
      "word_count": 18,
      "approx_duration_sec": 6.49
    },
    {
      "scene_index": 8,
      "sentence": "She knew it was the right thing to do.",
      "word_count": 9,
      "approx_duration_sec": 3.24
    },
    {
      "scene_index": 9,
      "sentence": "Moral: Honesty is the best policy.",
      "word_count": 6,
      "approx_duration_sec": 2.16
    }
  ]
}