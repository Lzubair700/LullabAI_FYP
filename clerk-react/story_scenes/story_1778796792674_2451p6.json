    {
      "scene_index": 0,
      "sentence": "The Lost Toy Lily was a sweet little girl who loved to play.",
      "word_count": 13,
      "approx_duration_sec": 4.95
    },
    {
      "scene_index": 1,
      "sentence": "One day, Lily was in the park when she found a shiny new toy.",
      "word_count": 14,
      "approx_duration_sec": 5.33
    },
    {
      "scene_index": 2,
      "sentence": "\"Wow, this is so fun!\" she said.",
      "word_count": 7,
      "approx_duration_sec": 2.67
    },
    {
      "scene_index": 3,
      "sentence": "Lily put the toy in her bag and ran home.",
      "word_count": 10,
      "approx_duration_sec": 3.81
    },
    {
      "scene_index": 4,
      "sentence": "When Lily got home, her mom asked, \"Where did you get that toy?\" Lily felt very sad.",
      "word_count": 17,
      "approx_duration_sec": 6.48
    },
    {
      "scene_index": 5,
      "sentence": "She said, \"I found it in the park.\" Her mom gave her a big hug.",
      "word_count": 15,
      "approx_duration_sec": 5.71
    },
    {
      "scene_index": 6,
      "sentence": "\"I'm proud of you for telling the truth.",
      "word_count": 8,
      "approx_duration_sec": 3.05
    },
    {
      "scene_index": 7,
      "sentence": "Honesty is the best policy.\" From that day on, Lily always tried to be honest.",
      "word_count": 15,
      "approx_duration_sec": 5.71
    },
    {
      "scene_index": 8,
      "sentence": "Moral: Honesty is the best policy.",
      "word_count": 6,
