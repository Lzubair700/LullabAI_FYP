      "word_count": 20,
      "approx_duration_sec": 6.78
    },
    {
      "scene_index": 5,
      "sentence": "When Daisy found Lily, Lily felt sad.",
      "word_count": 7,
      "approx_duration_sec": 2.37
    },
    {
